#!/usr/bin/env python3
"""drive-graduate — the earned-the-streak interlock (PRO-63).

  drive-graduate --check --log <drive-log.jsonl> [--repo R] [--days N]

Re-derives the graduation criteria from the drive-log, the integration branch, and the
disconfirm ledger (reusing drive-pulse so there is one source of the streak math). ALL of
these must hold before the system may graduate — i.e. before T05b auto-promote to main is
eligible to be enabled:

  1. revert/rollback was ACTUALLY checked against a repo (never graduate on unverified data)
  2. trust_streak >= streak_target (20 clean trailing auto-merges)
  3. fake_green == 0 over the window
  4. reverts_seen == 0 AND rolled_back == 0
  5. zero open disconfirm-ledger entries against the streak's merges (a human-flagged-but-
     not-git-reverted bad merge that still earned a streak point blocks graduation)

On pass, writes a dated graduation record (append-only, in the brain so the auto-commit
makes it tamper-evident) — only then is T05b eligible. This is a careful, one-way unlock:
the gate must fail closed, so any missing/unverifiable signal blocks rather than passes.

Exit 0 = graduated (record written / already present), 1 = not yet, 2 = usage/error.
"""
import argparse
import datetime
import importlib.util
import json
import os
import sys
from importlib.machinery import SourceFileLoader

HERE = os.path.dirname(os.path.abspath(__file__))
_loader = SourceFileLoader("drive_pulse", os.path.join(HERE, "drive-pulse"))
pulse = importlib.util.module_from_spec(importlib.util.spec_from_loader("drive_pulse", _loader))
_loader.exec_module(pulse)

GRADUATION_LOG = os.environ.get(
    "PSDRIVE_GRADUATION_LOG",
    os.path.expanduser("~/site/knowledge/brain/_automation/portfolio-status/drive-graduation.jsonl"))


def disconfirmed_shas():
    """Every sha a human flagged via drive-disconfirm (the open disconfirm ledger). A bad
    merge stays 'open' here until a human removes its line — there is no resolved state."""
    try:
        rows = [json.loads(l) for l in open(pulse.disconfirm_log_path(), encoding="utf-8") if l.strip()]
    except OSError:
        return []
    return [str(r.get("sha")) for r in rows if r.get("sha")]


def sha_match(a, b):
    return bool(a) and bool(b) and (a.startswith(b) or b.startswith(a))


def evaluate(log, repo, days):
    rows = [json.loads(l) for l in open(log, encoding="utf-8") if l.strip()]
    now = datetime.date.today()
    cur_start = now - datetime.timedelta(days=days)
    cur = [r for r in rows if cur_start <= pulse.parse_date(r["ts"]) < now]
    sig = pulse.goal_signals(cur, rows, repo)

    streak = sig.get("trust_streak") or 0
    target = sig.get("streak_target", 20)
    # The streak's actual merge events (trailing `streak`), checked over ALL history — NOT
    # the --days window. goal_signals' fake_green is window-scoped, so a fake-green merge
    # older than the window would read 0 there while still counting toward the streak. The
    # gate must verify the streak ITSELF: every merge it rests on was host-verified.
    evs = pulse.merge_events(rows)
    streak_events = evs[-streak:] if streak > 0 else []
    streak_shas = [e.get("merged_sha") for e in streak_events if e.get("merged_sha")]
    streak_fake = [e for e in streak_events if e.get("verify_required") and not e.get("verify_ran")]
    open_disc = [d for d in disconfirmed_shas() if any(sha_match(s, d) for s in streak_shas)]

    criteria = [
        # require BOTH signals actually verifiable (not the OR in revert_checked): graduating
        # claims zero reverts AND zero rollbacks, so neither may be None (un-checked).
        ("revert/rollback checked against a repo",
         sig.get("reverts_seen") is not None and sig.get("rolled_back") is not None),
        (f"trust_streak {streak}/{target}", streak >= target),
        (f"fake-green in streak: {len(streak_fake)} == 0", not streak_fake),
        (f"reverts_seen {sig.get('reverts_seen')} == 0", sig.get("reverts_seen") == 0),
        (f"rolled_back {sig.get('rolled_back')} == 0", sig.get("rolled_back") == 0),
        (f"open disconfirms vs streak: {len(open_disc)} == 0", not open_disc),
    ]
    return all(ok for _, ok in criteria), criteria, sig


def write_record(sig, repo):
    rec = {"ts": datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
           "graduated": True, "trust_streak": sig.get("trust_streak"),
           "streak_target": sig.get("streak_target", 20), "fake_green": sig.get("fake_green"),
           "reverts_seen": sig.get("reverts_seen"), "rolled_back": sig.get("rolled_back"),
           "merges_total": sig.get("merges_total"), "repo": repo}
    os.makedirs(os.path.dirname(GRADUATION_LOG), exist_ok=True)
    with open(GRADUATION_LOG, "a", encoding="utf-8") as f:
        f.write(json.dumps(rec, ensure_ascii=False) + "\n")
    return rec


def already_graduated():
    try:
        rows = [json.loads(l) for l in open(GRADUATION_LOG, encoding="utf-8") if l.strip()]
    except OSError:
        return None
    grads = [r for r in rows if r.get("graduated")]
    return grads[-1] if grads else None


def main(argv):
    ap = argparse.ArgumentParser(prog="drive-graduate")
    ap.add_argument("--check", action="store_true", help="evaluate the gate; write a record on pass")
    ap.add_argument("--log", required=True, help="drive-log.jsonl")
    ap.add_argument("--repo", help="repo whose integration branch is checked (required to graduate)")
    ap.add_argument("--days", type=int, default=7)
    ap.add_argument("--json", action="store_true")
    a = ap.parse_args(argv)
    if not a.check:
        ap.error("drive-graduate currently supports only --check")
    try:
        ok, criteria, sig = evaluate(a.log, a.repo, a.days)
    except (OSError, ValueError) as e:
        print(f"drive-graduate: cannot evaluate: {e}", file=sys.stderr)
        return 2

    prior = already_graduated()
    record = None
    if ok and not prior:
        record = write_record(sig, a.repo)

    if a.json:
        print(json.dumps({"graduated": ok, "criteria": [{"name": n, "ok": k} for n, k in criteria],
                          "record": record, "prior_graduation": prior,
                          "signals": sig}, ensure_ascii=False))
        return 0 if ok else 1

    print(f"=== drive-graduate --check {'· already graduated' if prior else ''} ===")
    for name, k in criteria:
        print(f"  [{'PASS' if k else 'FAIL'}] {name}")
    if ok:
        print("\nGRADUATED — T05b auto-promote is eligible to be enabled."
              + (f"\nrecord written: {GRADUATION_LOG}" if record else "\n(graduation already on record)"))
    else:
        print("\nNOT YET — fix the FAIL criteria. The gate fails closed; T05b stays human-gated.")
    return 0 if ok else 1


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
