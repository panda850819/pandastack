#!/usr/bin/env python3
"""backfill-learning-first-seen — one-time corpus migration for the compound-loop
ratchet (PRO-39 / Gap 1).

Walks a learnings tree and, for every learning file (type in pattern / pitfall /
architecture / preference) that is missing them, adds:

  - first_seen: <created date>   (falls back to the YYYY-MM-DD filename prefix)
  - recurrence: 1                (the baseline count; bumps on each future match)

Idempotent and additive: a file that already has a field is left untouched, and
no existing value is ever overwritten. Frontmatter only; the body is untouched.

  backfill-learning-first-seen <learnings_dir> [--dry-run]
"""
import os
import re
import sys

LEARNING_TYPES = {"pattern", "pitfall", "architecture", "preference", "learning"}
_DATE = re.compile(r"(\d{4}-\d{2}-\d{2})")
_KEY = re.compile(r"^([A-Za-z_][A-Za-z0-9_]*):")


def date_from_name(path):
    m = _DATE.match(os.path.basename(path))
    return m.group(1) if m else None


def process(path, dry):
    with open(path, encoding="utf-8") as f:
        lines = f.read().split("\n")
    if not lines or lines[0].strip() != "---":
        return False
    try:
        end = lines.index("---", 1)
    except ValueError:
        return False
    fm = lines[1:end]
    keys = {}
    for i, l in enumerate(fm):
        m = _KEY.match(l)
        if m:
            keys[m.group(1)] = i
    if "type" not in keys:
        return False
    typ = fm[keys["type"]].split(":", 1)[1].strip()
    if typ not in LEARNING_TYPES:
        return False

    additions = []
    if "first_seen" not in keys:
        val = None
        if "created" in keys:
            raw = fm[keys["created"]].split(":", 1)[1].strip().strip("'\"")
            m = _DATE.search(raw)   # normalize ISO timestamps -> YYYY-MM-DD
            val = m.group(1) if m else None
        if not val:
            val = date_from_name(path)
        if val:
            additions.append(f"first_seen: {val}")
    if "recurrence" not in keys:
        additions.append("recurrence: 1")
    if not additions:
        return False

    at = keys.get("key", keys["type"]) + 1   # insert just under key (or type)
    fm[at:at] = additions
    out = "\n".join(["---"] + fm + ["---"] + lines[end + 1:])
    if dry:
        print(f"WOULD update {path}: {', '.join(additions)}")
    else:
        with open(path, "w", encoding="utf-8") as f:
            f.write(out)
    return True


def main(argv):
    if not argv:
        sys.exit("usage: backfill-learning-first-seen <learnings_dir> [--dry-run]")
    root = argv[0]
    dry = "--dry-run" in argv[1:]
    n = 0
    for dirpath, _, files in os.walk(root):
        for name in files:
            if name.endswith(".md") and process(os.path.join(dirpath, name), dry):
                n += 1
    print(f"{'would update' if dry else 'updated'} {n} learning file(s) under {root}")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
