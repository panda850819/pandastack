#!/usr/bin/env python3
"""drive-log-distill — turn the driver's append-only ledger into constraints (PRO-40 / Gap 3).

drive-log.jsonl records every tick but nothing reads it back, so the same outcome
re-pays every run. This distills two recurring patterns into actionable items:

  - stuck-PASS: an id verified PASS in K+ ticks but never advanced -> auto-advance
    candidate (the loop keeps re-verifying green because the human never ran the advance).
  - persistent-gate: an id sitting in gate_ids across M+ ticks -> open an issue that
    names the blocker, instead of re-gating it forever.

Feeds retro-week Phase 1.6 (GC sweep). Proposes only; never advances or files anything.

  drive-log-distill <drive-log.jsonl> [--pass-k N] [--gate-m N] [--json]
"""
import argparse
import json
import sys
from collections import Counter


def distill(rows, pass_k, gate_m):
    pass_count = Counter()
    gate_count = Counter()
    for r in rows:
        for e in r.get("executed", []):
            if e.get("verdict") == "PASS":
                pass_count[e["id"]] += 1
        for gid in r.get("gate_ids", []):
            gate_count[gid] += 1
    stuck = sorted(((i, c) for i, c in pass_count.items() if c >= pass_k), key=lambda x: -x[1])
    gated = sorted(((i, c) for i, c in gate_count.items() if c >= gate_m), key=lambda x: -x[1])
    return stuck, gated


def main(argv):
    ap = argparse.ArgumentParser(prog="drive-log-distill")
    ap.add_argument("log")
    ap.add_argument("--pass-k", type=int, default=3, help="min PASS ticks to flag stuck-PASS")
    ap.add_argument("--gate-m", type=int, default=3, help="min gate ticks to flag persistent-gate")
    ap.add_argument("--json", action="store_true")
    a = ap.parse_args(argv)

    rows = [json.loads(l) for l in open(a.log, encoding="utf-8") if l.strip()]
    stuck, gated = distill(rows, a.pass_k, a.gate_m)

    if a.json:
        print(json.dumps({
            "stuck_pass": [{"id": i, "pass_ticks": c} for i, c in stuck],
            "persistent_gate": [{"id": i, "gate_ticks": c} for i, c in gated],
        }, ensure_ascii=False))
        return 0

    if not stuck and not gated:
        print(f"drive-log clean: nothing PASS>={a.pass_k} ticks or gated>={a.gate_m} ticks.")
        return 0
    if stuck:
        print(f"STUCK-PASS (verified green >= {a.pass_k} ticks, never advanced) -> auto-advance candidate:")
        for i, c in stuck:
            print(f"  {i}: PASS in {c} ticks")
    if gated:
        print(f"PERSISTENT-GATE (in gate_ids >= {a.gate_m} ticks) -> open an issue naming the blocker:")
        for i, c in gated:
            print(f"  {i}: gated in {c} ticks")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
