#!/usr/bin/env python3
"""learning-refresh — corpus staleness audit (PRO-45 / read-side, propose-only).

The loop's only staleness mechanism is passive suppression: effective-confidence decay
hides a learning from review output but never rewrites, deletes, or flags it. So the
corpus drifts against a moving repo and nobody audits what was written. This is the
correct-side entry point: a deterministic, headless sweep that surfaces learnings decay
has already silently suppressed and that recurrence is NOT keeping alive — candidates a
human (via retro-week Phase 1.6) decides to mark `status: stale` / archive.

PROPOSES ONLY. Never mutates a learning, never deletes. Marking and consolidation stay a
human/retro decision (the "回得來、炸不到 main" boundary: read-side audit escalates, it
does not act). Candidate = effective confidence < 3 (below the reading threshold) AND
recurrence < 2 (not a repeat offender) AND source != user-stated AND not already stale.

  learning-refresh <learnings_dir> [--now YYYY-MM-DD] [--json]
"""
import argparse
import datetime
import json
import os
import re
import sys

LEARNING_TYPES = {"pattern", "pitfall", "architecture", "preference", "learning"}
CONF_WORD = {"high": 8, "medium": 5, "moderate": 5, "low": 3, "speculation": 1}
_KEY = re.compile(r"^([A-Za-z_][A-Za-z0-9_]*):\s*(.*)$")
_DATE = re.compile(r"\d{4}-\d{2}-\d{2}")


def frontmatter(path):
    with open(path, encoding="utf-8") as f:
        lines = f.read().split("\n")
    if not lines or lines[0].strip() != "---":
        return None
    try:
        end = lines.index("---", 1)
    except ValueError:
        return None
    d = {}
    for l in lines[1:end]:
        m = _KEY.match(l)
        if m:
            d[m.group(1)] = m.group(2).strip()
    return d


def conf_num(v):
    try:
        return int(v)
    except (ValueError, TypeError):
        return CONF_WORD.get(str(v).strip().lower(), 5)


def int_or(v, default):
    try:
        return int(str(v).strip())
    except (ValueError, TypeError):
        return default


def created_date(d):
    for k in ("created", "first_seen"):
        if k in d:
            m = _DATE.search(d[k])
            if m:
                return datetime.date.fromisoformat(m.group(0))
    return None


def candidate(d, now):
    if not d or d.get("type") not in LEARNING_TYPES:
        return None
    if d.get("status", "active").strip().lower() == "stale":
        return None
    if (d.get("source") or "").strip().lower() == "user-stated":
        return None              # user-stated never decays
    if int_or(d.get("recurrence", "1"), 1) >= 2:
        return None              # a repeat offender earns its place
    created = created_date(d)
    if not created:
        return None
    eff = max(0, conf_num(d.get("confidence", "5")) - (now - created).days // 30)
    if eff >= 3:                 # still above the reading threshold — not stale yet
        return None
    return {"key": d.get("key", "?"), "eff_conf": eff,
            "recurrence": int_or(d.get("recurrence", "1"), 1),
            "reason": f"effective confidence {eff} < 3 (decayed below reading threshold), "
                      f"recurrence < 2 — silently suppressed; review for stale / archive"}


def main(argv):
    ap = argparse.ArgumentParser(prog="learning-refresh")
    ap.add_argument("dir")
    ap.add_argument("--now", help="anchor date YYYY-MM-DD (default today)")
    ap.add_argument("--json", action="store_true")
    a = ap.parse_args(argv)
    now = datetime.date.fromisoformat(a.now) if a.now else datetime.date.today()

    cands = []
    for dirpath, _, files in os.walk(a.dir):
        for name in files:
            if name.endswith(".md"):
                p = os.path.join(dirpath, name)
                c = candidate(frontmatter(p), now)
                if c:
                    cands.append({"path": p, **c})
    cands.sort(key=lambda c: c["eff_conf"])

    if a.json:
        print(json.dumps({"now": now.isoformat(), "candidates": cands}, ensure_ascii=False))
        return 0
    if not cands:
        print(f"learning-refresh: no stale candidates as of {now.isoformat()} "
              "(nothing decayed below threshold without recurrence).")
        return 0
    print(f"STALE CANDIDATES ({len(cands)}) — propose status:stale / archive (retro decides):")
    for c in cands:
        print(f"  [{c['eff_conf']}] {c['key']}  — {c['path']}")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
